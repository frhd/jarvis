{
  "name": "telegram-bot",
  "version": "1.0.0",
  "description": "Telegram bot using grammy",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/fix-esm-imports.js && cp -r src/db/migrations dist/db/",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "prod:start": "npm run build && node dist/index.js",
    "prod:pm2": "npm run build && pm2 start ecosystem.config.cjs",
    "prod:pm2:stop": "pm2 stop jarvis",
    "prod:pm2:restart": "pm2 restart jarvis",
    "prod:pm2:logs": "pm2 logs jarvis",
    "prod:pm2:monit": "pm2 monit",
    "prod:pm2:status": "pm2 status",
    "prod:launchd:install": "cp deploy/com.jarvis.telegram.plist ~/Library/LaunchAgents/ && launchctl load ~/Library/LaunchAgents/com.jarvis.telegram.plist",
    "prod:launchd:uninstall": "launchctl unload ~/Library/LaunchAgents/com.jarvis.telegram.plist && rm ~/Library/LaunchAgents/com.jarvis.telegram.plist",
    "prod:launchd:start": "launchctl start com.jarvis.telegram",
    "prod:launchd:stop": "launchctl stop com.jarvis.telegram",
    "prod:docker:up": "docker compose up -d --build",
    "prod:docker:down": "docker compose down",
    "prod:docker:logs": "docker compose logs -f jarvis",
    "logs": "tail -f logs/jarvis.log",
    "logs:error": "tail -f logs/jarvis-error.log",
    "regression": "tsx tests/regression/index.ts",
    "check:circular": "madge --circular --extensions ts src/",
    "db:backfill:identity": "tsx src/db/backfill-unified-identity.ts",
    "db:backfill:memory-refs": "tsx src/db/backfill-memory-refs.ts"
  },
  "keywords": [
    "telegram",
    "bot",
    "grammy"
  ],
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@playwright/mcp": "^0.0.68",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.14.1",
    "better-sqlite3": "^12.5.0",
    "croner": "^10.0.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "duck-duck-scrape": "^2.2.7",
    "ical.js": "^2.2.1",
    "input": "^1.0.1",
    "jose": "^6.1.3",
    "nanoid": "^5.1.6",
    "playwright": "^1.59.0-alpha-1771104257000",
    "qrcode-terminal": "^0.12.0",
    "sqlite-vec": "^0.1.7-alpha.2",
    "telegram": "^2.26.22",
    "tsdav": "^2.3.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.3",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^4.0.16",
    "drizzle-kit": "^0.31.8",
    "madge": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
