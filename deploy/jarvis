#!/bin/bash
#
# Jarvis Production Management CLI
#
# Usage: jarvis <command> [options]
#
# Commands:
#   start       Start Jarvis (PM2)
#   stop        Stop Jarvis
#   restart     Restart Jarvis
#   status      Show status
#   logs        Tail logs
#   monit       Open PM2 monitoring dashboard
#   build       Build TypeScript
#   install     Install as launchd service (auto-start on boot)
#   uninstall   Remove launchd service

set -e

JARVIS_DIR="/Users/jarvis/src/jarvis"
cd "$JARVIS_DIR"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_status() { echo -e "${BLUE}[JARVIS]${NC} $1"; }
print_success() { echo -e "${GREEN}[JARVIS]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[JARVIS]${NC} $1"; }
print_error() { echo -e "${RED}[JARVIS]${NC} $1"; }

# Check if PM2 is installed
check_pm2() {
    if ! command -v pm2 &> /dev/null; then
        print_error "PM2 is not installed. Install with: npm install -g pm2"
        exit 1
    fi
}

# Build TypeScript
do_build() {
    print_status "Building TypeScript..."
    npm run build
    print_success "Build complete!"
}

# Start with PM2
do_start() {
    check_pm2

    # Check if already running
    if pm2 list | grep -q "jarvis.*online"; then
        print_warning "Jarvis is already running. Use 'jarvis restart' to restart."
        return
    fi

    # Build first
    do_build

    print_status "Starting Jarvis with PM2..."
    pm2 start ecosystem.config.cjs
    print_success "Jarvis started!"
    echo ""
    pm2 status jarvis
}

# Stop
do_stop() {
    check_pm2
    print_status "Stopping Jarvis..."
    pm2 stop jarvis 2>/dev/null || print_warning "Jarvis was not running"
    print_success "Jarvis stopped."
}

# Restart
do_restart() {
    check_pm2

    # Build first
    do_build

    print_status "Restarting Jarvis..."
    pm2 restart jarvis 2>/dev/null || pm2 start ecosystem.config.cjs
    print_success "Jarvis restarted!"
}

# Status
do_status() {
    check_pm2
    echo ""
    pm2 status jarvis 2>/dev/null || print_warning "Jarvis is not managed by PM2"
    echo ""

    # Show recent logs
    if [ -f "logs/jarvis.log" ]; then
        echo -e "${BLUE}Recent logs:${NC}"
        tail -5 logs/jarvis.log
    fi
}

# Tail logs
do_logs() {
    local lines="${1:-100}"
    local mode="${2:-all}"

    case "$mode" in
        error)
            if [ -f "logs/jarvis-error.log" ]; then
                tail -f -n "$lines" logs/jarvis-error.log
            else
                print_warning "No error log file found"
            fi
            ;;
        pm2)
            check_pm2
            pm2 logs jarvis --lines "$lines"
            ;;
        *)
            if [ -f "logs/jarvis.log" ]; then
                tail -f -n "$lines" logs/jarvis.log
            else
                print_warning "No log file found. Using PM2 logs..."
                check_pm2
                pm2 logs jarvis --lines "$lines"
            fi
            ;;
    esac
}

# PM2 monitoring
do_monit() {
    check_pm2
    pm2 monit
}

# Install launchd service
do_install() {
    print_status "Installing Jarvis as a launchd service..."

    # Build first
    do_build

    # Copy plist
    cp deploy/com.jarvis.telegram.plist ~/Library/LaunchAgents/

    # Load service
    launchctl load ~/Library/LaunchAgents/com.jarvis.telegram.plist

    print_success "Jarvis installed as a system service!"
    print_status "It will now start automatically on login."
    print_status "Use 'jarvis logs' to monitor output."
}

# Uninstall launchd service
do_uninstall() {
    print_status "Uninstalling Jarvis launchd service..."

    # Unload service
    launchctl unload ~/Library/LaunchAgents/com.jarvis.telegram.plist 2>/dev/null || true

    # Remove plist
    rm -f ~/Library/LaunchAgents/com.jarvis.telegram.plist

    print_success "Jarvis launchd service removed."
}

# PM2 startup (configure auto-start)
do_startup() {
    check_pm2
    print_status "Configuring PM2 to start on boot..."
    pm2 startup
    pm2 save
    print_success "PM2 startup configured!"
}

# Help
do_help() {
    echo ""
    echo -e "${BLUE}Jarvis Production Management CLI${NC}"
    echo ""
    echo "Usage: jarvis <command> [options]"
    echo ""
    echo "Commands:"
    echo "  start              Start Jarvis (builds first, uses PM2)"
    echo "  stop               Stop Jarvis"
    echo "  restart            Restart Jarvis (builds first)"
    echo "  status             Show current status"
    echo "  logs [n] [type]    Tail logs (default: 100 lines, all)"
    echo "                     Types: all, error, pm2"
    echo "  monit              Open PM2 real-time dashboard"
    echo "  build              Build TypeScript only"
    echo "  startup            Configure PM2 auto-start on boot"
    echo "  install            Install as launchd service"
    echo "  uninstall          Remove launchd service"
    echo ""
    echo "Examples:"
    echo "  jarvis start           # Build and start"
    echo "  jarvis logs 200        # Tail last 200 lines"
    echo "  jarvis logs 50 error   # Tail error log"
    echo "  jarvis monit           # Real-time dashboard"
    echo "  jarvis startup         # Enable auto-start"
    echo ""
}

# Main
case "${1:-help}" in
    start)
        do_start
        ;;
    stop)
        do_stop
        ;;
    restart)
        do_restart
        ;;
    status)
        do_status
        ;;
    logs)
        do_logs "${2:-100}" "${3:-all}"
        ;;
    monit)
        do_monit
        ;;
    build)
        do_build
        ;;
    startup)
        do_startup
        ;;
    install)
        do_install
        ;;
    uninstall)
        do_uninstall
        ;;
    help|--help|-h)
        do_help
        ;;
    *)
        print_error "Unknown command: $1"
        do_help
        exit 1
        ;;
esac
