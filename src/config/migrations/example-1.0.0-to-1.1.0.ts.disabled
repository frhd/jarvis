/**
 * Example Migration: 1.0.0 to 1.1.0
 *
 * This is a REAL example of what a migration would look like.
 * It's disabled by default (.disabled extension) - remove that to activate it.
 *
 * DESCRIPTION:
 * This example migration demonstrates adding semantic memory features
 * that were introduced in a hypothetical version 1.1.0:
 * - Added embedding configuration
 * - Added memory configuration
 * - Added RAG configuration
 * - Added semantic cache configuration
 * - Renamed LLM 'url' field to 'baseUrl' for consistency
 *
 * BREAKING CHANGES:
 * - LLM configuration field 'url' is now 'baseUrl'
 *   Environment variable LLM_URL should be changed to LLM_BASE_URL
 */

import { ConfigMigrator } from '../version';

const FROM_VERSION = '1.0.0';
const TO_VERSION = '1.1.0';
const DESCRIPTION = 'Added semantic memory features and renamed LLM URL field';

/**
 * Register migration from 1.0.0 to 1.1.0
 *
 * This migration:
 * 1. Adds embedding configuration (disabled by default)
 * 2. Adds memory configuration (disabled by default)
 * 3. Adds RAG configuration (disabled by default)
 * 4. Adds semantic cache configuration (disabled by default)
 * 5. Renames llm.url to llm.baseUrl
 */
export function migration_1_0_0_to_1_1_0(migrator: ConfigMigrator): void {
  migrator.registerMigration(
    FROM_VERSION,
    TO_VERSION,
    (config) => {
      // Create a copy to avoid mutating the original
      const newConfig = { ...config };

      // 1. Add embedding configuration
      // Default to disabled to maintain backward compatibility
      newConfig.embedding = {
        enabled: false,
        model: 'nomic-embed-text',
        dimensions: 768,
        timeoutMs: 10000,
      };

      // 2. Add memory configuration
      // Default to disabled to maintain backward compatibility
      newConfig.memory = {
        enabled: false,
        maxMemoriesPerSender: 100,
        archiveAfterDays: 90,
        minConfidence: 50,
      };

      // 3. Add RAG configuration
      // Default to disabled to maintain backward compatibility
      newConfig.rag = {
        enabled: false,
        topK: 10,
        similarityThreshold: 0.7,
        recencyDecayHours: 168, // 7 days
        maxContextTokens: 2000,
        recentMessagesCount: 5,
      };

      // 4. Add semantic cache configuration
      // Default to disabled to maintain backward compatibility
      newConfig.cache = {
        enabled: false,
        similarityThreshold: 0.92,
        maxEntries: 10000,
        ttl: {
          simpleGreeting: 24,
          factualQuestion: 168, // 7 days
          personalQuestion: 720, // 30 days
          default: 24,
        },
        cacheableIntents: [
          'simple_greeting',
          'time_greeting',
          'farewell',
          'gratitude',
          'factual_question',
          'personal_question',
        ],
      };

      // 5. Rename LLM 'url' field to 'baseUrl' for consistency
      // This is a BREAKING CHANGE but we handle it gracefully
      if (newConfig.llm && 'url' in newConfig.llm) {
        newConfig.llm = {
          ...newConfig.llm,
          baseUrl: newConfig.llm.url,
        };
        // Remove old field
        delete newConfig.llm.url;
      }

      return newConfig;
    },
    DESCRIPTION
  );
}

/**
 * Rollback function (for documentation purposes)
 *
 * If you need to manually rollback from 1.1.0 to 1.0.0:
 * 1. Remove the new configuration sections
 * 2. Restore the old field name
 */
export function rollback_1_1_0_to_1_0_0(config: any): any {
  const rolledBackConfig = { ...config };

  // Remove new sections
  delete rolledBackConfig.embedding;
  delete rolledBackConfig.memory;
  delete rolledBackConfig.rag;
  delete rolledBackConfig.cache;

  // Restore old field name
  if (rolledBackConfig.llm && 'baseUrl' in rolledBackConfig.llm) {
    rolledBackConfig.llm = {
      ...rolledBackConfig.llm,
      url: rolledBackConfig.llm.baseUrl,
    };
    delete rolledBackConfig.llm.baseUrl;
  }

  return rolledBackConfig;
}

/**
 * Example usage in tests:
 *
 * describe('Migration 1.0.0 to 1.1.0', () => {
 *   it('should add semantic memory features', () => {
 *     const oldConfig = {
 *       database: { path: '/data/jarvis.db' },
 *       llm: {
 *         enabled: true,
 *         url: 'http://localhost:11434',
 *         model: 'mistral',
 *       },
 *     };
 *
 *     const migrator = new ConfigMigrator();
 *     migration_1_0_0_to_1_1_0(migrator);
 *
 *     const result = migrator.migrate(oldConfig, '1.0.0', '1.1.0');
 *
 *     expect(result.success).toBe(true);
 *     expect(result.config.embedding).toBeDefined();
 *     expect(result.config.memory).toBeDefined();
 *     expect(result.config.rag).toBeDefined();
 *     expect(result.config.cache).toBeDefined();
 *     expect(result.config.llm.baseUrl).toBe('http://localhost:11434');
 *     expect(result.config.llm.url).toBeUndefined();
 *   });
 *
 *   it('should handle configs without LLM section', () => {
 *     const minimalConfig = {
 *       database: { path: '/data/jarvis.db' },
 *     };
 *
 *     const migrator = new ConfigMigrator();
 *     migration_1_0_0_to_1_1_0(migrator);
 *
 *     const result = migrator.migrate(minimalConfig, '1.0.0', '1.1.0');
 *
 *     expect(result.success).toBe(true);
 *     expect(result.config.embedding).toBeDefined();
 *   });
 * });
 */

/**
 * ENVIRONMENT VARIABLE CHANGES:
 *
 * Users upgrading from 1.0.0 to 1.1.0 should update their .env file:
 *
 * CHANGED:
 * - LLM_URL -> LLM_BASE_URL (rename)
 *
 * NEW (all optional with safe defaults):
 * - EMBEDDING_ENABLED=false
 * - EMBEDDING_MODEL=nomic-embed-text
 * - EMBEDDING_DIMENSIONS=768
 * - EMBEDDING_TIMEOUT_MS=10000
 *
 * - MEMORY_ENABLED=false
 * - MAX_MEMORIES_PER_SENDER=100
 * - MEMORY_ARCHIVE_AFTER_DAYS=90
 * - MEMORY_MIN_CONFIDENCE=50
 *
 * - RAG_ENABLED=false
 * - RAG_TOP_K=10
 * - RAG_SIMILARITY_THRESHOLD=0.7
 * - RAG_RECENCY_DECAY_HOURS=168
 * - RAG_MAX_CONTEXT_TOKENS=2000
 * - RAG_RECENT_MESSAGES_COUNT=5
 *
 * - CACHE_ENABLED=false
 * - CACHE_SIMILARITY_THRESHOLD=0.92
 * - CACHE_MAX_ENTRIES=10000
 * - CACHE_TTL_GREETING_HOURS=24
 * - CACHE_TTL_FACTUAL_HOURS=168
 * - CACHE_TTL_PERSONAL_HOURS=720
 * - CACHE_TTL_DEFAULT_HOURS=24
 */
